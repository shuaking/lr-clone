# YouTube Data API v3 (可选 - 用于视频搜索和元数据)
# 获取方式: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here

# Supabase (Phase 2 需要 - 用户认证和数据库)
# 获取方式: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Sentry (可选 - 错误监控)
# 获取方式: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# 环境标识
NODE_ENV=production
